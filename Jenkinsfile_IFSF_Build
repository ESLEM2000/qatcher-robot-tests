// Pipeline Jenkins : BUILD IFSF (ReleasePackage-ITA0148-IFSF-TETRA style)
//
// Ce job clone le dépôt ita-emb-app-ifsf, lance le build, et publie les artefacts .7z
// (DevProxy, IFSF_Lib, IFSF, XMLConfigDLL, XMLConfigLib) utilisés par le job IFSF-install.
//
// --- BUILD PARAMETERS (Build with Parameters) ---
//
// | USE_GIT             | bool   | false    | false = sans Git (pas de clone). Sources dans BUILD_SOURCE_DIR ou workspace. |
// | BUILD_SOURCE_DIR    | string | (vide)   | Sans Git : répertoire des sources (ex. C:\Ingedev_Workspaces\ReleasePackage-ITA0148-WLFA). Vide = workspace. |
// | GIT_REPO_URL        | string | (défaut) | Avec Git : URL du dépôt à cloner. |
// | GIT_BRANCH          | string | main     | Avec Git : branche à construire. |
// | GIT_CREDENTIALS_ID  | string | (vide)   | Avec Git : ID credential pour le clone. |
// | BUILD_COMMAND       | string | (vide)   | Commande de build complète. Prioritaire sur BUILD_XML_PATH. |
// | BUILD_XML_PATH      | string | (défaut) | Chemin vers build.xml (si BUILD_COMMAND vide). |
// | INGEDEV_ROOT        | string | (défaut) | Répertoire IngeDev COMPLET (antCmdLine.bat + lltc), PAS le projet. Ex: C:\Ingenico\IngeDev_8.22.0.6. Préférer un chemin sans espaces. |
//
// --- Installation IngeDev complète (lltc requis) ---
// antCmdLine.bat appelle « lltc ». Le dossier doit contenir lltc.exe ou lltc.bat. Sinon : obtenir le package IngeDev COMPLET ou copier tout le dossier depuis une machine où le build fonctionne. Voir INSTALL_INGEDEV.md (section « Installation complète et composant lltc »).
//
// --- Sans Git (pas de SCM, pas de clone) ---
// 1. New Item → IFSF-Build → Pipeline → OK
// 2. Pipeline → Definition : "Pipeline script" (coller ce fichier). Pas de "Pipeline script from SCM".
// 3. Build with Parameters : USE_GIT = false, BUILD_SOURCE_DIR = chemin des sources, BUILD_COMMAND si besoin.
//

pipeline {
    agent any

    parameters {
        booleanParam(
            name: 'USE_GIT',
            defaultValue: false,
            description: 'Si false : pas de clone Git. Sources dans BUILD_SOURCE_DIR ou dans le workspace.'
        )
        string(
            name: 'BUILD_SOURCE_DIR',
            defaultValue: '',
            description: 'Sans Git : répertoire des sources (ex. C:\\Ingedev_Workspaces\\ReleasePackage-ITA0148-WLFA). Vide = workspace.'
        )
        string(
            name: 'GIT_REPO_URL',
            defaultValue: 'git@github.com:worldlineMSITA/ita-emb-app-ifsf.git',
            description: 'Avec Git : URL du dépôt à cloner.'
        )
        string(
            name: 'GIT_BRANCH',
            defaultValue: 'main',
            description: 'Avec Git : branche à construire.'
        )
        string(
            name: 'GIT_CREDENTIALS_ID',
            defaultValue: '',
            description: 'Avec Git : ID credential Jenkins pour le clone.'
        )
        string(
            name: 'BUILD_COMMAND',
            defaultValue: '',
            description: 'Commande de build complète. Si vide, BUILD_XML_PATH ou détection auto (build.xml, BuildPackage/Ant/build.xml).'
        )
        string(
            name: 'BUILD_XML_PATH',
            defaultValue: '',
            description: 'Chemin vers build.xml (utilisé si BUILD_COMMAND vide). Vide = détection auto (build.xml, BuildPackage/Ant/build.xml dans les sources ou workspace).'
        )
        string(
            name: 'INGEDEV_ROOT',
            defaultValue: 'C:\\Ingenico\\IngeDev_8.22.0.6',
            description: 'Répertoire IngeDev COMPLET (antCmdLine.bat + lltc.exe ou lltc.bat), PAS le projet. Préférer un chemin SANS ESPACES. Voir INSTALL_INGEDEV.md si erreur « lltc absent ».'
        )
    }

    options {
        timeout(time: 60, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '30'))
    }

    stages {
        stage('Checkout') {
            when { expression { return params.USE_GIT } }
            steps {
                script {
                    def url = params.GIT_REPO_URL?.trim()
                    def branch = params.GIT_BRANCH?.trim() ?: 'main'
                    def credId = params.GIT_CREDENTIALS_ID?.trim()
                    if (!url) {
                        error 'GIT_REPO_URL doit être renseigné (Build with Parameters).'
                    }
                    def userConfig = [url: url]
                    if (credId) { userConfig.credentialsId = credId }
                    checkout([$class: 'GitSCM', branches: [[name: '*/' + branch]], userRemoteConfigs: [userConfig]])
                }
            }
        }

        stage('Build') {
            steps {
                script {
                    // Nettoyer les chemins : retirer backticks et guillemets (copier-coller / UI Jenkins peut ajouter des ")
                    def sanitizePath = { String s ->
                        def t = (s ?: '').trim().replaceAll(/`/, '')
                        while (t.startsWith('"') && t.endsWith('"') && t.length() > 1) { t = t[1..-2].trim() }
                        return t
                    }
                    def rawDir = sanitizePath(params.BUILD_SOURCE_DIR ?: '')
                    def srcDir = rawDir.split(/\s+/).find { it } ?: ''
                    // Sans Git : exiger BUILD_SOURCE_DIR ou BUILD_XML_PATH ou BUILD_COMMAND (éviter build dans workspace vide)
                    if (!params.USE_GIT && !srcDir && !params.BUILD_XML_PATH?.trim() && !params.BUILD_COMMAND?.trim()) {
                        error "Sans Git : renseigner au moins un des paramètres suivants (Build with Parameters) : BUILD_SOURCE_DIR (ex. C:\\Ingedev_Workspaces\\ReleasePackage-ITA0148-WLFA), ou BUILD_XML_PATH (chemin complet vers build.xml), ou BUILD_COMMAND. INGEDEV_ROOT doit pointer vers IngeDev complet (avec lltc) si vous utilisez antCmdLine.bat."
                    }
                    def runBuild = {
                        def cmd = sanitizePath(params.BUILD_COMMAND ?: '')
                        def buildXml = sanitizePath(params.BUILD_XML_PATH ?: '')
                        def ingedevRoot = sanitizePath(params.INGEDEV_ROOT ?: '')
                        // Si BUILD_XML_PATH vide mais sources + IngeDev : utiliser BuildPackage\Ant\build.xml dans srcDir
                        if (!cmd && srcDir && ingedevRoot && !buildXml && !isUnix()) {
                            def candidate = (srcDir + '/BuildPackage/Ant/build.xml').replace('/', '\\')
                            if (fileExists(candidate)) { buildXml = candidate }
                        }
                        if (!cmd && buildXml && srcDir) {
                            if (ingedevRoot && !isUnix()) {
                                // Vérifier que lltc est présent (antCmdLine.bat en a besoin)
                                def lltcCheck = bat(
                                    script: """
if exist \"${ingedevRoot}\\lltc.exe\" exit /b 0
if exist \"${ingedevRoot}\\lltc.bat\" exit /b 0
echo IngeDev incomplet : lltc absent dans ${ingedevRoot}
exit /b 1
""",
                                    returnStatus: true
                                )
                                if (lltcCheck != 0) {
                                    error "IngeDev incomplet : le composant 'lltc' est absent dans ${ingedevRoot}. antCmdLine.bat en a besoin. Obtenez le package IngeDev COMPLET (avec lltc) ou copiez tout le dossier depuis une machine où le build fonctionne. Voir INSTALL_INGEDEV.md (section 'Installation complète et composant lltc')."
                                }
                                // IngeDev : antCmdLine.bat. Chemins passés via env. Toujours cd vers INGEDEV_ROOT entre guillemets (pas de chemin 8.3) pour que lltc trouve ses DLL.
                                def envVars = ["SRC_DIR=${srcDir}", "BUILD_XML_PATH=${buildXml}", "INGEDEV_ROOT=${ingedevRoot}"]
                                withEnv(envVars) {
                                    bat """
setlocal enabledelayedexpansion
cd /d "!INGEDEV_ROOT!"
call antCmdLine.bat "!SRC_DIR!" "!BUILD_XML_PATH!"
endlocal
"""
                                }
                                return
                            }
                            cmd = isUnix() ? "ant -f '${buildXml}'" : "ant -f \"${buildXml}\""
                        }
                        if (cmd) {
                            if (isUnix()) { sh cmd } else { bat cmd }
                        } else {
                            if (isUnix()) {
                                if (fileExists('build.xml')) { sh 'ant -f build.xml' }
                                else if (fileExists('BuildPackage/Ant/build.xml')) { sh 'ant -f BuildPackage/Ant/build.xml' }
                                else if (fileExists('build.sh')) { sh 'chmod +x build.sh && ./build.sh' }
                                else { error "Aucun build.xml/build.sh trouvé. Renseigner BUILD_COMMAND ou BUILD_XML_PATH." }
                            } else {
                                if (fileExists('build.xml')) { bat 'ant -f build.xml' }
                                else if (fileExists('BuildPackage\\Ant\\build.xml')) { bat 'ant -f BuildPackage\\Ant\\build.xml' }
                                else if (fileExists('BuildPackage/Ant/build.xml')) { bat 'ant -f BuildPackage/Ant/build.xml' }
                                else if (fileExists('Ant/build.xml')) { bat 'ant -f Ant/build.xml' }
                                else if (fileExists('build.bat')) { bat 'call build.bat' }
                                else {
                                    error "Aucun build.xml/build.bat trouvé dans le répertoire de build. Sans Git : renseigner BUILD_SOURCE_DIR (ex. C:\\Ingedev_Workspaces\\ReleasePackage-ITA0148-WLFA ou chemin vers votre projet contenant BuildPackage\\Ant\\build.xml). Sinon : BUILD_XML_PATH (chemin complet vers build.xml) ou BUILD_COMMAND."
                                }
                            }
                        }
                    }
                    if (srcDir) {
                        dir(srcDir) { runBuild() }
                    } else {
                        runBuild()
                    }
                }
            }
        }

        stage('Archive artifacts') {
            steps {
                script {
                    def rawDir = params.BUILD_SOURCE_DIR?.trim() ?: ''
                    def srcDir = rawDir.split(/\s+/).find { it } ?: ''
                    def isAbsolute = srcDir && (srcDir.contains(':') || srcDir.startsWith('/'))
                    if (isAbsolute) {
                        // Jenkins n'archive que sous le workspace : copier les .7z vers le workspace
                        def dest = env.WORKSPACE
                        if (isUnix()) {
                            sh "find '${srcDir}' -name '*.7z' -exec cp {} '${dest}' \\; || true"
                        } else {
                            def srcEsc = srcDir.replace("'", "''")
                            def destEsc = dest.replace("'", "''")
                            bat "powershell -NoProfile -Command \"Get-ChildItem -Path '${srcEsc}' -Recurse -Filter '*.7z' -ErrorAction SilentlyContinue | Copy-Item -Destination '${destEsc}' -Force\""
                        }
                    }
                    def pattern = (srcDir && !isAbsolute) ? "${srcDir}/**/*.7z".replace('\\', '/') : '**/*.7z'
                    archiveArtifacts artifacts: pattern, fingerprint: true, allowEmptyArchive: true
                    echo 'Archive artefacts : si aucun .7z n\'a été archivé, vérifier que le build produit bien des .7z (DevProxy, IFSF, etc.) dans le répertoire de build ou BUILD_SOURCE_DIR.'
                }
            }
        }
    }

    post {
        success {
            echo 'Build IFSF réussi. Artefacts .7z archivés (DevProxy, IFSF, XMLConfigDLL, etc.). Le job IFSF-install peut utiliser ce build (Copy Artifacts ou IFSF_JENKINS_URL).'
        }
        failure {
            echo 'Build IFSF en échec. Si erreur "lltc absent" ou "lltc n\'est pas reconnu" : le dossier INGEDEV_ROOT doit être une installation COMPLÈTE (antCmdLine.bat + lltc). Obtenir le package IngeDev complet ou copier tout le dossier depuis une machine où le build fonctionne. Préférer un chemin SANS ESPACES. Voir INSTALL_INGEDEV.md (section « Installation complète et composant lltc »).'
        }
    }
}
