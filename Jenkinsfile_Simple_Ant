pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/ESLEM2000/qatcher-robot-tests.git'
            }
        }
        stage('Build & Test Packages') {
            steps {
                script {
                    def timestamp = new Date().format("yyyy-MM-dd_HH-mm-ss")
                    // Ecrire la liste des modules dans un fichier pour eviter l'echo cmd dans returnStdout
                    bat "powershell -NoProfile -Command \"Out-File -InputObject (Get-ChildItem -Path src -Directory -ErrorAction SilentlyContinue).Name -FilePath modules.txt -Encoding ascii\""
                    def modulesRaw = readFile('modules.txt').trim()
                    def modules = modulesRaw.split("\\r?\\n").collect { it.trim() }.findAll { name ->
                        name.length() > 0 && !name.contains('>') && !name.contains('powershell') && !name.contains('\\\\') && !name.contains(':')
                    }
                    if (modules.isEmpty()) {
                        error "Aucun sous-dossier dans src/ ou dossier src/ absent. Build arrete."
                    }

                    modules.each { module ->
                        def modulePath = "src\\${module}"

                        // Verification que le dossier n'est pas vide (derniere ligne = resultat, echo cmd sur les premieres)
                        def filesCountOut = bat(script: "powershell -NoProfile -Command \"(Get-ChildItem -LiteralPath '${modulePath}').Count\"", returnStdout: true).trim()
                        def filesCount = filesCountOut.split("\\r?\\n").findAll { it.trim().length() > 0 }.reverse().find { it.isNumber() } ?: filesCountOut.trim()
                        if (filesCount == "0") {
                            error "Le module ${module} est vide ! Build arrete."
                        }

                        // Verification de placeholder.bat (derniere ligne = True/False)
                        def placeholderOut = bat(script: "powershell -NoProfile -Command \"Test-Path -LiteralPath '${modulePath}\\\\placeholder.bat'\"", returnStdout: true).trim()
                        def placeholderExists = placeholderOut.split("\\r?\\n").findAll { it.trim().length() > 0 }.reverse().find { it == "True" || it == "False" } ?: placeholderOut.trim()
                        if (placeholderExists != "True") {
                            error "Le fichier placeholder.bat est manquant dans ${module} ! Build arrete."
                        }

                        // Copie des fichiers
                        bat """
                            mkdir dist\\${module}
                            xcopy ${modulePath} dist\\${module} /E /I /Y
                        """

                        // Test d’exécution de placeholder.bat
                        bat """
                            echo Test execution placeholder.bat pour ${module}
                            call dist\\${module}\\placeholder.bat
                        """

                        // Packaging
                        bat """
                            "C:\\Program Files\\7-Zip\\7z.exe" a dist\\${module}_V${timestamp}_Binaries.7z dist\\${module}\\*
                        """
                    }
                }
            }
        }
    }
    post {
        success {
            archiveArtifacts artifacts: 'dist/*.7z', fingerprint: true
        }
        failure {
            echo "Le build a échoué car un module était vide, incomplet ou que placeholder.bat n'a pas pu s'exécuter."
        }
    }
}






