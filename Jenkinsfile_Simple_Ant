// Pipeline Jenkins : Git + Ant + archive .7z
// Si erreur "Couldn't find any revision to build" : le dépôt GitHub est vide → pousser au moins un commit (ce Jenkinsfile + build.xml, etc.) sur la branche main.

pipeline {
    agent any

    parameters {
        string(
            name: 'GIT_REPO_URL',
            defaultValue: 'https://github.com/ESLEM2000/qatcher-robot-tests.git',
            description: 'URL du dépôt Git à cloner.'
        )
        string(
            name: 'GIT_BRANCH',
            defaultValue: 'main',
            description: 'Branche à construire (si erreur "no revision", essayer master).'
        )
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: "${params.GIT_BRANCH}", url: params.GIT_REPO_URL
            }
        }
        stage('Build Packages') {
            steps {
                script {
                    if (isUnix()) {
                        sh 'ant -f build.xml all'
                    } else {
                        bat 'ant -f build.xml all'
                    }
                }
            }
        }
    }
    post {
        success {
            archiveArtifacts artifacts: 'dist/*.7z', fingerprint: true
        }
    }
}

