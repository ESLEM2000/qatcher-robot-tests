def modules = bat(
    script: "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-ChildItem src -Directory | ForEach-Object { $_.Name }\"",
    returnStdout: true
).trim().split("\\r?\\n")

modules.each { module ->
    def modulePath = "src\\${module}"

    def filesCount = bat(
        script: "powershell -NoProfile -ExecutionPolicy Bypass -Command \"(Get-ChildItem ${modulePath}).Count\"",
        returnStdout: true
    ).trim()
    if (filesCount == "0") {
        error "Le module ${module} est vide ! Build arrêté."
    }

    def placeholderExists = bat(
        script: "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Test-Path ${modulePath}\\placeholder.bat\"",
        returnStdout: true
    ).trim()
    if (placeholderExists != "True") {
        error "Le fichier placeholder.bat est manquant dans ${module} ! Build arrêté."
    }

    bat """
        mkdir dist\\${module}
        xcopy ${modulePath} dist\\${module} /E /I /Y
        call dist\\${module}\\placeholder.bat
        if %ERRORLEVEL% NEQ 0 exit /b %ERRORLEVEL%
        "C:\\Program Files\\7-Zip\\7z.exe" a dist\\${module}_V${timestamp}_Binaries.7z dist\\${module}\\*
    """
}




