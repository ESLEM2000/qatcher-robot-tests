pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/ESLEM2000/qatcher-robot-tests.git'
            }
        }
        stage('Build & Test Packages') {
            steps {
                script {
                    def timestamp = new Date().format("yyyy-MM-dd_HH-mm-ss")

                    // Liste les sous-dossiers de src avec DIR (%%i car execute dans un .bat)
                    def modulesOut = bat(
                        script: "for /d %%i in (src\\*) do @echo %%~nxi",
                        returnStdout: true
                    ).trim()
                    def modules = modulesOut.split("\\r?\\n").collect { it.trim() }.findAll { name ->
                        name.length() > 0 && !name.contains('>') && !name.contains(':')
                    }
                    if (modules.isEmpty()) {
                        error "Aucun sous-dossier dans src/ ou dossier src/ absent. Build arrete."
                    }

                    modules.each { module ->
                        def modulePath = "src\\${module}"

                        // Verification que le dossier n'est pas vide (derniere ligne = nombre)
                        def countOut = bat(
                            script: "dir /b \"${modulePath}\" 2>nul | find /c /v \"\"",
                            returnStdout: true
                        ).trim()
                        def filesCount = countOut.split("\\r?\\n").findAll { it.trim().length() > 0 }.reverse().find { it.isNumber() } ?: countOut.trim()
                        if (filesCount == "0") {
                            error "Le module ${module} est vide ! Build arrete."
                        }

                        // Verification de placeholder.bat (ligne True/False)
                        def placeOut = bat(
                            script: "if exist \"${modulePath}\\placeholder.bat\" (echo True) else (echo False)",
                            returnStdout: true
                        ).trim()
                        def placeholderExists = placeOut.split("\\r?\\n").findAll { it.trim().length() > 0 }.reverse().find { it == "True" || it == "False" } ?: placeOut.trim()
                        if (placeholderExists != "True") {
                            error "Le fichier placeholder.bat est manquant dans ${module} ! Build arrete."
                        }

                        // Copie des fichiers
                        bat """
                            if not exist dist\\${module} mkdir dist\\${module}
                            xcopy \"${modulePath}\" \"dist\\${module}\" /E /I /Y
                        """

                        // Affichage du contenu copie
                        bat "echo Contenu de dist\\${module} : & dir \"dist\\${module}\""

                        // Test d'execution de placeholder.bat (sans apostrophe pour eviter erreur cmd)
                        bat """
                            echo Test execution placeholder.bat pour ${module}
                            call \"dist\\${module}\\placeholder.bat\"
                            if errorlevel 1 exit /b 1
                        """

                        // Packaging
                        bat """
                            "C:\\Program Files\\7-Zip\\7z.exe" a "dist\\${module}_V${timestamp}_Binaries.7z" "dist\\${module}\\*"
                        """
                    }
                }
            }
        }
    }
    post {
        success {
            archiveArtifacts artifacts: 'dist/*.7z', fingerprint: true
        }
        failure {
            echo "Le build a echoue car un module etait vide, incomplet ou que placeholder.bat n'a pas pu s'executer."
        }
    }
}






