<project name="ReleasePackage-ITA0148-WLFA" default="all" basedir=".">

    <!-- Chemin 7-Zip : par défaut "7z" (si dans PATH). Sur Jenkins Windows, passer -Dsevenzip.executable="C:\Program Files\7-Zip\7z.exe" -->
    <property name="sevenzip.executable" value="7z"/>

    <!-- Préparation des répertoires (créer src/devproxy et src/ifsf s'ils n'existent pas, pour clone Git vide) -->
    <target name="init">
        <mkdir dir="dist"/>
        <mkdir dir="src/devproxy"/>
        <mkdir dir="src/ifsf"/>
        <echo file="src/devproxy/placeholder.bat" message="@echo off&#10;echo Placeholder - remplacer par le contenu DevProxy"/>
        <echo file="src/ifsf/placeholder.bat" message="@echo off&#10;echo Placeholder - remplacer par le contenu IFSF"/>
    </target>

    <!-- Assemblage DevProxy -->
    <target name="assemble-devproxy" depends="init">
        <copy todir="dist/devproxy" includeEmptyDirs="true">
            <fileset dir="src/devproxy"/>
        </copy>
    </target>

    <!-- Assemblage IFSF -->
    <target name="assemble-ifsf" depends="init">
        <copy todir="dist/ifsf" includeEmptyDirs="true">
            <fileset dir="src/ifsf"/>
        </copy>
    </target>

    <!-- Packaging DevProxy (vérifier que sevenzip.executable est passé par Jenkins sur Windows) -->
    <target name="package-devproxy" depends="assemble-devproxy">
        <exec executable="${sevenzip.executable}" failonerror="true">
            <arg value="a"/>
            <arg value="dist/DevProxy.7z"/>
            <arg value="dist/devproxy/*"/>
        </exec>
    </target>

    <!-- Packaging IFSF -->
    <target name="package-ifsf" depends="assemble-ifsf">
        <exec executable="${sevenzip.executable}" failonerror="true">
            <arg value="a"/>
            <arg value="dist/IFSF.7z"/>
            <arg value="dist/ifsf/*"/>
        </exec>
    </target>

    <!-- Cible globale -->
    <target name="all" depends="package-devproxy,package-ifsf"/>

    <!-- Nettoyage -->
    <target name="clean">
        <delete dir="dist"/>
    </target>

</project>

